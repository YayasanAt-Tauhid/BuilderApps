{
	"name": "builderpro",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.5.0",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"type-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"type-check:backend": "tsc --noEmit -p workers/backend/tsconfig.json",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "pnpm test:unit --run && pnpm test:integration --run",
		"test:unit": "vitest --config vitest.config.ts",
		"test:integration": "vitest --config vitest.integration.config.ts",
		"test:e2e": "playwright test",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "wrangler d1 migrations apply builderpro-db --local",
		"db:migrate:production": "wrangler d1 migrations apply builderpro-db --env production --remote",
		"deploy:backend": "wrangler deploy --config workers/backend/wrangler.jsonc",
		"deploy": "vite build && wrangler deploy",
		"deploy:all": "pnpm deploy:backend && pnpm deploy"
	},
	"dependencies": {
		"@inlang/paraglide-js": "2.18.1",
		"@noble/hashes": "^2.2.0",
		"@oslojs/crypto": "1.0.1",
		"@oslojs/encoding": "1.1.0",
		"clsx": "2.1.1",
		"drizzle-orm": "0.45.2",
		"fflate": "0.8.3",
		"sveltekit-superforms": "2.30.1",
		"tailwind-merge": "3.6.0",
		"tweetnacl": "^1.0.3",
		"ulid": "3.0.2",
		"valibot": "1.4.1"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.16.10",
		"@cloudflare/workers-types": "4.20260530.1",
		"@eslint/js": "10.0.1",
		"@inlang/plugin-message-format": "4.4.0",
		"@playwright/test": "1.60.0",
		"@sveltejs/adapter-cloudflare": "7.2.8",
		"@sveltejs/kit": "2.61.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.0",
		"@types/node": "25.9.1",
		"@vitest/coverage-v8": "4.1.7",
		"drizzle-kit": "0.31.10",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.19.0",
		"globals": "17.6.0",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "4.0.1",
		"prettier-plugin-tailwindcss": "0.8.0",
		"svelte": "5.56.0",
		"svelte-check": "4.4.8",
		"svelte-eslint-parser": "1.7.0",
		"tailwindcss": "4.3.0",
		"tw-animate-css": "1.4.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.0",
		"vite": "8.0.14",
		"vitest": "4.1.7",
		"wrangler": "4.95.0"
	}
}
